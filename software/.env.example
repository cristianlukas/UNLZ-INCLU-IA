# Server
INCLUIA_HOST=0.0.0.0
INCLUIA_PORT=5000
INCLUIA_DEBUG=0

# Driver: simulator | faster_whisper | whisper_cpp
INCLUIA_DRIVER=simulator
INCLUIA_HISTORY_SIZE=200
INCLUIA_FALLBACK_SIM=1

# AP metadata exposed to frontend
INCLUIA_AP_SSID=Inclu-IA_Classroom
INCLUIA_AP_URL=http://192.168.4.1:5000

# Simulator
INCLUIA_SIM_INTERVAL_S=1.2
INCLUIA_SIM_LINES=Bienvenidos a Inclu-IA|Subtitulado en tiempo real para aula

# faster-whisper
INCLUIA_FW_MODEL=tiny
INCLUIA_FW_COMPUTE_TYPE=int8
INCLUIA_FW_LANGUAGE=es
INCLUIA_FW_PHRASE_LIMIT_S=4
INCLUIA_FW_VAD=1
# INCLUIA_AUDIO_DEVICE_INDEX=0
# INCLUIA_AUDIO_SAMPLE_RATE=48000
INCLUIA_SOCKET_TRANSPORT=polling

# whisper.cpp
INCLUIA_WCPP_BIN=/home/pi/whisper.cpp/build/bin/whisper-stream
INCLUIA_WCPP_MODEL=/home/pi/whisper.cpp/models/ggml-base.bin
INCLUIA_WCPP_THREADS=4
INCLUIA_WCPP_STEP_MS=2000
INCLUIA_WCPP_LENGTH_MS=8000
INCLUIA_WCPP_VAD_THRESHOLD=0.6
